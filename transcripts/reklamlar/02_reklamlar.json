    },
    {
      "timestamps": {
        "from": "00:08:12,040",
        "to": "00:08:14,760"
      },
      "offsets": {
        "from": 492040,
        "to": 494760
      },
      "text": " Kebap bir numara yazayım."
    },
    {
      "timestamps": {
        "from": "00:08:14,760",
        "to": "00:08:16,760"
      },
      "offsets": {
        "from": 494760,
        "to": 496760
      },
      "text": " Şimdi buradan buradan çıkacak. Kebap bir numara."
    },
    {
      "timestamps": {
        "from": "00:08:16,760",
        "to": "00:08:21,880"
      },
      "offsets": {
        "from": 496760,
        "to": 501880
      },
      "text": " Bu daha çok Facebook kısmında gözüküyor bu arada. Burada Instagram'a geldiğiniz zaman primeliteks daha önemli oluyor."
    },
    {
      "timestamps": {
        "from": "00:08:21,880",
        "to": "00:08:23,640"
      },
      "offsets": {
        "from": 501880,
        "to": 503640
      },
      "text": " Türkiye'nin bir numara kebabçısı."
    },
    {
      "timestamps": {
        "from": "00:08:23,640",
        "to": "00:08:28,280"
      },
      "offsets": {
        "from": 503640,
        "to": 508280
      },
      "text": " Kebap bir numara tarzı böyle sorular da şurada burada çıkartıyor da çok ekisirem önemli değil."
    },
    {
      "timestamps": {
        "from": "00:08:28,280",
        "to": "00:08:30,840"
      },
      "offsets": {
        "from": 508280,
        "to": 510840
      },
      "text": " Sonra alakta deskripsin dediği yerde şurası."
    },
    {
      "timestamps": {
        "from": "00:08:30,840",
        "to": "00:08:35,080"
      },
      "offsets": {
        "from": 510840,
        "to": 515080
      },
      "text": " Bunun altındaki yer, 1-3-1-3-1-3-3-3-3-3-3 yazalım görüntüsün diye."
    },
    {
      "timestamps": {
        "from": "00:08:35,080",
        "to": "00:08:38,040"
      },
      "offsets": {
        "from": 515080,
        "to": 518040
      },
      "text": " Burada işte hani yorumlar yazabilirsiniz."
    },
    {
      "timestamps": {
        "from": "00:08:38,040",
        "to": "00:08:42,040"
      },
      "offsets": {
        "from": 518040,
        "to": 522040
      },
      "text": " İşte 4.9-9-6-6 tarzı böyle küçük şeyler yazabilirsiniz."
    },
    {
      "timestamps": {
        "from": "00:08:42,040",
        "to": "00:08:45,240"
      },
      "offsets": {
        "from": 522040,
        "to": 525240
      },
      "text": " ana mantık da burada bu şekilde çıkıyor olacak."
    },
    {
      "timestamps": {
        "from": "00:08:45,240",
        "to": "00:08:49,800"
      },
      "offsets": {
        "from": 525240,
        "to": 529800
      },
      "text": " Kol tek şimdi kısmında bizim edefimiz satış olduğu için buradan ben şopnava seçiyor."
    },
    {
      "timestamps": {
        "from": "00:08:49,800",
        "to": "00:08:53,000"
      },
      "offsets": {
        "from": 529800,
        "to": 533000
      },
      "text": " Olacağım. Devamında buradan aşağı iniyoruz."
    },
    {
      "timestamps": {
        "from": "00:08:53,000",
        "to": "00:08:55,560"
      },
      "offsets": {
        "from": 533000,
        "to": 535560
      },
      "text": " Webste event ser şartı açmanız lazım."
    },
    {
      "timestamps": {
        "from": "00:08:55,560",
        "to": "00:08:59,800"
      },
      "offsets": {
        "from": 535560,
        "to": 539800
      },
      "text": " Burada açtığınız zaman direkt olarak pixelinizi görüyor olacaksınız ki pixeli."
    },
    {
      "timestamps": {
        "from": "00:08:59,800",
        "to": "00:09:01,960"
      },
      "offsets": {
        "from": 539800,
        "to": 541960
      },
      "text": " Burada bunun üzerinden takip ediyor olacağız."
    },
    {
      "timestamps": {
        "from": "00:09:01,960",
        "to": "00:09:05,000"
      },
      "offsets": {
        "from": 541960,
        "to": 545000
      },
      "text": " Burada pixeliniz aktif olduğu zaman burada yeşil yanıyor olacak."
    },
    {
      "timestamps": {
        "from": "00:09:05,000",
        "to": "00:09:08,040"
      },
      "offsets": {
        "from": 545000,
        "to": 548040
      },
      "text": " O yüzden de herhangi bir problem çekmiyor. Olacaksınız."
    },
    {
      "timestamps": {
        "from": "00:09:08,040",
        "to": "00:09:11,560"
      },
      "offsets": {
        "from": 548040,
        "to": 551560
      },
      "text": " Sonra alakta bakın burada görelde parametres diye bir muhabbet var."
    },
    {
      "timestamps": {
        "from": "00:09:11,560",
        "to": "00:09:13,880"
      },
      "offsets": {
        "from": 551560,
        "to": 553880
      },
      "text": " Burada aşağıda yorumlara ekleyeceğim."
    },
    {
      "timestamps": {
        "from": "00:09:13,880",
        "to": "00:09:16,520"
      },
      "offsets": {
        "from": 553880,
        "to": 556520
      },
      "text": " Kodu direkt olarak alıp yapıştırabilirsiniz."
    },
    {
      "timestamps": {
        "from": "00:09:16,520",
        "to": "00:09:21,000"
      },
      "offsets": {
        "from": 556520,
        "to": 561000
      },
      "text": " Bunun anamantığı da bazen Facebook sizin aldığınız siparişleri"
    },
    {
      "timestamps": {
        "from": "00:09:21,000",
        "to": "00:09:23,800"
      },
      "offsets": {
        "from": 561000,
        "to": 563800
      },
      "text": " hangi rektam setinden aldığınızı takip edemeye biliyor."
    },
    {
      "timestamps": {
        "from": "00:09:23,800",
        "to": "00:09:27,320"
      },
      "offsets": {
        "from": 563800,
        "to": 567320
      },
      "text": " Biz bunun manuel olarak koyuyoruz ki şopfaya girdiğimiz zaman"
    },
    {
      "timestamps": {
        "from": "00:09:27,320",
        "to": "00:09:31,000"
      },
      "offsets": {
        "from": 567320,
        "to": 571000
      },
      "text": " buyurunun hangi rektam setinden geldiğini görebiliyor olalım."
    },
    {
      "timestamps": {
        "from": "00:09:31,000",
        "to": "00:09:34,840"
      },
      "offsets": {
        "from": 571000,
        "to": 574840
      },
      "text": " Bunun detaylı kısımlarını bir sonraki videoda zaten görüyor olacaksınız."
    },
    {
      "timestamps": {
        "from": "00:09:34,840",
        "to": "00:09:39,000"
      },
      "offsets": {
        "from": 574840,
        "to": 579000
      },
      "text": " ana mantık da burada bütün işlerinizi bitirdikten sonra geliyorsunuz."
    },
    {
      "timestamps": {
        "from": "00:09:39,000",
        "to": "00:09:42,280"
      },
      "offsets": {
        "from": 579000,
        "to": 582280
      },
      "text": " Buradan çarpıya bastığınız zaman zaten direkt olarak sana soruyor."
    },
    {
      "timestamps": {
        "from": "00:09:42,280",
        "to": "00:09:45,080"
      },
      "offsets": {
        "from": 582280,
        "to": 585080
      },
      "text": " Bunları publishlayayım mı diye ya böyle yapabilirsiniz."
    },
    {
      "timestamps": {
        "from": "00:09:45,080",
        "to": "00:09:47,400"
      },
      "offsets": {
        "from": 585080,
        "to": 587400
      },
      "text": " Ya buradan tıklayıp publisha basabilirsiniz."
    },
    {
      "timestamps": {
        "from": "00:09:47,400",
        "to": "00:09:49,480"
      },
      "offsets": {
        "from": 587400,
        "to": 589480
      },
      "text": " Tek tek yapmanızı önermem vakit kaybı."
    },
    {
      "timestamps": {
        "from": "00:09:49,480",
        "to": "00:09:54,200"
      },
      "offsets": {
        "from": 589480,
        "to": 594200
      },
      "text": " Ya da buradan direkt olarak çıkıp şuradan revi ve publish kısmınıza bastığınız zaman da"
    },
    {
      "timestamps": {
        "from": "00:09:54,200",
        "to": "00:09:57,480"
      },
      "offsets": {
        "from": 594200,
        "to": 597480
      },
      "text": " gene rektamlarınızı yayına koyuyor olacaktır."
    },
    {
      "timestamps": {
        "from": "00:09:57,480",
        "to": "00:10:00,840"
      },
      "offsets": {
        "from": 597480,
        "to": 600840
      },
      "text": " Şimdi bir sonraki videoda da bunun canlı olarak nasıl yapıldığını"
    },
    {
      "timestamps": {
        "from": "00:10:00,840",
        "to": "00:10:05,320"
      },
      "offsets": {
        "from": 600840,
        "to": 605320
      },
      "text": " benim Türkiye'deki Instagram seriğimde nasıl rektamları scale edip iyi sonuçlar aldığımı"
    },
    {
      "timestamps": {
        "from": "00:10:05,320",
        "to": "00:10:07,320"
      },
      "offsets": {
        "from": 605320,
        "to": 607320
      },
      "text": " detaylıca inceliyor olalım."
    }
  ]
