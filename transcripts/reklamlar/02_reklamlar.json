  "transcription": [
    {
      "timestamps": {
        "from": "00:00:00,000",
        "to": "00:00:02,560"
      },
      "offsets": {
        "from": 0,
        "to": 2560
      },
      "text": " Tamamdır şimdi reklamlar kısmını inceliyor olacağız."
    },
    {
      "timestamps": {
        "from": "00:00:02,560",
        "to": "00:00:08,080"
      },
      "offsets": {
        "from": 2560,
        "to": 8080
      },
      "text": " Anamantıklar reklam dediğimiz kısm bizim videolarımızın metaya para vererek insanların önüne düşürmek oluyor."
    },
    {
      "timestamps": {
        "from": "00:00:08,080",
        "to": "00:00:09,840"
      },
      "offsets": {
        "from": 8080,
        "to": 9840
      },
      "text": " Burada şu kısmı unutmamak lazım."
    },
    {
      "timestamps": {
        "from": "00:00:09,840",
        "to": "00:00:15,240"
      },
      "offsets": {
        "from": 9840,
        "to": 15240
      },
      "text": " Eğer sizin videolarınız organekte işe yaramıyorsan, yani siz organekte satışlar alamıyorsanız,"
    },
    {
      "timestamps": {
        "from": "00:00:15,240",
        "to": "00:00:20,160"
      },
      "offsets": {
        "from": 15240,
        "to": 20160
      },
      "text": " buna para verdiğiniz sürece insanların önüne zorla çıkardığınız sürece gene satış alamıyor olacaksınız."
    },
    {
      "timestamps": {
        "from": "00:00:20,160",
        "to": "00:00:24,960"
      },
      "offsets": {
        "from": 20160,
        "to": 24960
      },
      "text": " O yüzden ürünün organekte doğrulamadığınız sürece reklamları çıkmak çok mantıklı bir strateji olmuyor."
    },
    {
      "timestamps": {
        "from": "00:00:24,960",
        "to": "00:00:28,400"
      },
      "offsets": {
        "from": 24960,
        "to": 28400
      },
      "text": " Şimdi reklamlar kısmında sürekli duyduğunuz iki terim olacak."
    },
    {
      "timestamps": {
        "from": "00:00:28,400",
        "to": "00:00:31,160"
      },
      "offsets": {
        "from": 28400,
        "to": 31160
      },
      "text": " Burada bir aibiyomuz olacak, bir de cibiyomuz olacak."
    },
    {
      "timestamps": {
        "from": "00:00:31,160",
        "to": "00:00:33,080"
      },
      "offsets": {
        "from": 31160,
        "to": 33080
      },
      "text": " Şimdi bunların farkları neler?"
    },
    {
      "timestamps": {
        "from": "00:00:33,080",
        "to": "00:00:37,600"
      },
      "offsets": {
        "from": 33080,
        "to": 37600
      },
      "text": " Şimdi aibiyo dediğimiz kısmı ile bildiğiniz gibi sizin reklamda bir kampanyalarınız var."
    },
    {
      "timestamps": {
        "from": "00:00:37,600",
        "to": "00:00:43,120"
      },
      "offsets": {
        "from": 37600,
        "to": 43120
      },
      "text": " Bu kampanyaların altında reklam setleriniz var, reklam set yazalım bunun altında reklamlarınız var."
    },
    {
      "timestamps": {
        "from": "00:00:43,120",
        "to": "00:00:47,880"
      },
      "offsets": {
        "from": 43120,
        "to": 47880
      },
      "text": " Şimdi bizim burada aibiyo dediğimiz muhabbet her reklam setinin ayrı bütçesi olması."
    },
    {
      "timestamps": {
        "from": "00:00:47,880",
        "to": "00:00:52,040"
      },
      "offsets": {
        "from": 47880,
        "to": 52040
      },
      "text": " Atıyorum, sizin burada üç tane ayrı reklam setiniz var, üç ayrı video test ediyorsunuz."
    },
    {
      "timestamps": {
        "from": "00:00:52,040",
        "to": "00:00:57,520"
      },
      "offsets": {
        "from": 52040,
        "to": 57520
      },
      "text": " Diyorsunuz ki bizim ilk videomuz, yüz lira harcısın, ikinci videomuz, iki yüz lira harcısın, üçüncü videomuz, beş yüz lira harcısın."
    },
    {
      "timestamps": {
        "from": "00:00:57,520",
        "to": "00:01:02,520"
      },
      "offsets": {
        "from": 57520,
        "to": 62520
      },
      "text": " Bizim bu şekilde her reklam setin ayrı para ayrı bütç ayırmamız aibiyo olarak geçiyor."
    },
    {
      "timestamps": {
        "from": "00:01:02,520",
        "to": "00:01:03,720"
      },
      "offsets": {
        "from": 62520,
        "to": 63720
      },
      "text": " Buradaki mantık ne?"
    },
    {
      "timestamps": {
        "from": "00:01:03,720",
        "to": "00:01:07,920"
      },
      "offsets": {
        "from": 63720,
        "to": 67920
      },
      "text": " Her reklam setinin bütçesini biz manuel olarak değiştirebiliyoruz."
    },
    {
      "timestamps": {
        "from": "00:01:07,920",
        "to": "00:01:12,920"
      },
      "offsets": {
        "from": 67920,
        "to": 72920
      },
      "text": " Bu sayede farklı reklam videolarına test edip hangisinin iyi sonuçu verdiğini görebiliyoruz."
    },
    {
      "timestamps": {
        "from": "00:01:12,920",
        "to": "00:01:15,960"
      },
      "offsets": {
        "from": 72920,
        "to": 75960
      },
      "text": " Birazdan reklam panelini de örneklerini gösterecek, anlatıyorum."
    },
    {
      "timestamps": {
        "from": "00:01:15,960",
        "to": "00:01:23,360"
      },
      "offsets": {
        "from": 75960,
        "to": 83360
      },
      "text": " Peki, cibiyoda dediğimiz kısmı ile, cibiyoda da siz reklam setine para vermek yerine direkt olarak kampanyaya bütç ayırıyorsunuz."
    },
    {
      "timestamps": {
        "from": "00:01:23,360",
        "to": "00:01:24,640"
      },
      "offsets": {
        "from": 83360,
        "to": 84640
      },
      "text": " Diyorsunuz ki bir daha var."
    },
    {
      "timestamps": {
        "from": "00:01:24,640",
        "to": "00:01:26,320"
      },
      "offsets": {
        "from": 84640,
        "to": 86320
      },
      "text": " Benim elimde 1000 lira para var."
    },
    {
      "timestamps": {
        "from": "00:01:26,320",
        "to": "00:01:27,520"
      },
      "offsets": {
        "from": 86320,
        "to": 87520
      },
      "text": " Sen bu 1000 liraya aldı."
    },
    {
      "timestamps": {
        "from": "00:01:27,520",
        "to": "00:01:30,160"
      },
      "offsets": {
        "from": 87520,
        "to": 90160
      },
      "text": " Buradaki üç reklam setine kafana göre dağıtık."
    },
    {
      "timestamps": {
        "from": "00:01:30,160",
        "to": "00:01:33,080"
      },
      "offsets": {
        "from": 90160,
        "to": 93080
      },
      "text": " Bu demek ki bir tanesini atıyorum. Hiç para harcamayacak."
    },
    {
      "timestamps": {
        "from": "00:01:33,080",
        "to": "00:01:35,360"
      },
      "offsets": {
        "from": 93080,
        "to": 95360
      },
      "text": " Öbür kesini atıyorum, yüz lira harcayacak."
    },
    {
      "timestamps": {
        "from": "00:01:35,360",
        "to": "00:01:39,440"
      },
      "offsets": {
        "from": 95360,
        "to": 99440
      },
      "text": " Bakacak ki algoritma bu üçüncü reklam setinden çok güzel sonuç oluyor."
    },
    {
      "timestamps": {
        "from": "00:01:39,440",
        "to": "00:01:42,280"
      },
      "offsets": {
        "from": 99440,
        "to": 102280
      },
      "text": " Ne olacak? 900 lirayı buna harcay olacak."
    },
    {
      "timestamps": {
        "from": "00:01:42,280",
        "to": "00:01:46,800"
      },
      "offsets": {
        "from": 102280,
        "to": 106800
      },
      "text": " Şimdi peki buradaki skeyli mantığı nasıl, ürünlerisiz, baktığınız organekte iyi gidiyorsunuz."
    },
    {
      "timestamps": {
        "from": "00:01:46,800",
        "to": "00:01:50,000"
      },
      "offsets": {
        "from": 106800,
        "to": 110000
      },
      "text": " Bunları reklama koyduğunuz, reklamdan da güzel soluşlar oluyorsunuz."
    },
    {
      "timestamps": {
        "from": "00:01:50,000",
        "to": "00:01:51,600"
      },
      "offsets": {
        "from": 110000,
        "to": 111600
      },
      "text": " Artık işiz skeyli kısmına geldi."
    },
    {
      "timestamps": {
        "from": "00:01:51,600",
        "to": "00:01:54,320"
      },
      "offsets": {
        "from": 111600,
        "to": 114320
      },
      "text": " Şimdi bildiğiniz gibi biz aibiyo açtığımız zaman."
    },
    {
      "timestamps": {
        "from": "00:01:54,320",
        "to": "00:01:57,000"
      },
      "offsets": {
        "from": 114320,
        "to": 117000
      },
      "text": " Bunlara atıyorum 200 lira başlangıç bütçesi verdik."
    },
    {
      "timestamps": {
        "from": "00:01:57,000",
        "to": "00:01:58,160"
      },
      "offsets": {
        "from": 117000,
        "to": 118160
      },
      "text": " 3'de 200 lira harcıyor."
    },
    {
      "timestamps": {
        "from": "00:01:58,160",
        "to": "00:01:59,480"
      },
      "offsets": {
        "from": 118160,
        "to": 119480
      },
      "text": " İyi gitmeye başladığı zaman."
    },
    {
      "timestamps": {
        "from": "00:01:59,480",
        "to": "00:02:01,920"
      },
      "offsets": {
        "from": 119480,
        "to": 121920
      },
      "text": " Bunların bütçesini 400 liraya yaptık."
    },
    {
      "timestamps": {
        "from": "00:02:01,920",
        "to": "00:02:06,560"
      },
      "offsets": {
        "from": 121920,
        "to": 126560
      },
      "text": " Şimdi gidip bu reklamlar çok iyi giderken, bunları çok agresif bir şekilde skeylediğiniz zaman."
    },
    {
      "timestamps": {
        "from": "00:02:06,560",
        "to": "00:02:09,360"
      },
      "offsets": {
        "from": 126560,
        "to": 129360
      },
      "text": " Reklamlar tekrardan optimiz olma muhabbeti var."
    },
    {
      "timestamps": {
        "from": "00:02:09,360",
        "to": "00:02:13,440"
      },
      "offsets": {
        "from": 129360,
        "to": 133440
      },
      "text": " Siz eğer bütçeyi çok agresif bir şekilde aibiyoda artırıyor olursanız"
    },
    {
      "timestamps": {
        "from": "00:02:13,440",
        "to": "00:02:16,160"
      },
      "offsets": {
        "from": 133440,
        "to": 136160
      },
      "text": " bu reklamların optimizasyonunu bozuyoruz."
    },
    {
      "timestamps": {
        "from": "00:02:16,160",
        "to": "00:02:17,920"
      },
      "offsets": {
        "from": 136160,
        "to": 137920
      },
      "text": " Optimizasyon bozulduğu zaman ne oluyor?"
    },
    {
      "timestamps": {
        "from": "00:02:17,920",
        "to": "00:02:20,240"
      },
      "offsets": {
        "from": 137920,
        "to": 140240
      },
      "text": " Reklam tekrardan öğrenme muhabbetine giriyor."
    },
    {
      "timestamps": {
        "from": "00:02:20,240",
        "to": "00:02:24,280"
      },
      "offsets": {
        "from": 140240,
        "to": 144280
      },
      "text": " O yüzden burada çok agresif bir şekilde aibiyoda skeyledemiyor oluyorsunuz."
    },
    {
      "timestamps": {
        "from": "00:02:24,280",
        "to": "00:02:26,000"
      },
      "offsets": {
        "from": 144280,
        "to": 146000
      },
      "text": " Peki işin siybiyo boyutun asıl."
    },
    {
      "timestamps": {
        "from": "00:02:26,000",
        "to": "00:02:32,240"
      },
      "offsets": {
        "from": 146000,
        "to": 152240
      },
      "text": " Hatırlasanız siz siybiyoda kampanyaye para veriyordunuz ve algoritma otomatik olarak ne kadar para harcacağını hesaplıyordu."
    },
    {
      "timestamps": {
        "from": "00:02:32,240",
        "to": "00:02:34,760"
      },
      "offsets": {
        "from": 152240,
        "to": 154760
      },
      "text": " Burada siz ilk başta 1000 lirayla başladınız."
    },
    {
      "timestamps": {
        "from": "00:02:34,760",
        "to": "00:02:38,600"
      },
      "offsets": {
        "from": 154760,
        "to": 158600
      },
      "text": " 1. kötü gitti, 2. derdini anlattı, 3. en iyi gitti."
    },
    {
      "timestamps": {
        "from": "00:02:38,600",
        "to": "00:02:41,400"
      },
      "offsets": {
        "from": 158600,
        "to": 161400
      },
      "text": " Şimdi siz bu sefer 2000 lira harcırdığınız zaman."
    },
    {
      "timestamps": {
        "from": "00:02:41,400",
        "to": "00:02:45,640"
      },
      "offsets": {
        "from": 161400,
        "to": 165640
      },
      "text": " 2000 lira yine algoritma seçip hangisine dağıtacağını kendi seçtiği için."
    },
    {
      "timestamps": {
        "from": "00:02:45,640",
        "to": "00:02:48,840"
      },
      "offsets": {
        "from": 165640,
        "to": 168840
      },
      "text": " Burada optimizasyonla ilgili bir problem yaşamıyor oluyorsunuz."
    },
    {
      "timestamps": {
        "from": "00:02:48,840",
        "to": "00:02:51,760"
      },
      "offsets": {
        "from": 168840,
        "to": 171760
      },
      "text": " O yüzden siz işin skeyel kısmına geçtiğiniz zaman."
    },
    {
      "timestamps": {
        "from": "00:02:51,760",
        "to": "00:02:54,640"
      },
      "offsets": {
        "from": 171760,
        "to": 174640
      },
      "text": " Artık birazcık da agresif para harcımıya başladığınız zaman."
    },
    {
      "timestamps": {
        "from": "00:02:54,640",
        "to": "00:03:00,840"
      },
      "offsets": {
        "from": 174640,
        "to": 180840
      },
      "text": " Bizim hedeflerimiz artık daha çok siybiyo açarak bunun fiyatına agresif bir şekilde artırma üzerine olay olacak."
    },
    {
      "timestamps": {
        "from": "00:03:00,840",
        "to": "00:03:05,880"
      },
      "offsets": {
        "from": 180840,
        "to": 185880
      },
      "text": " Anamantıkta iyibiyonun ve siybiyonun farkına anlatıyorsanız birazcık daha bunları nasıl kuracağınıza bakalım."
    },
    {
      "timestamps": {
        "from": "00:03:05,880",
        "to": "00:03:08,360"
      },
      "offsets": {
        "from": 185880,
        "to": 188360
      },
      "text": " Tamamdır. Şimdi de reklam sayfasına geldik."
    },
    {
      "timestamps": {
        "from": "00:03:08,360",
        "to": "00:03:10,680"
      },
      "offsets": {
        "from": 188360,
        "to": 190680
      },
      "text": " Burada sıfırdan bir reklam kuralım."
    },
    {
      "timestamps": {
        "from": "00:03:10,680",
        "to": "00:03:13,440"
      },
      "offsets": {
        "from": 190680,
        "to": 193440
      },
      "text": " Şimdi burada reklam kurmaya gerideğiniz zaman."
    },
    {
      "timestamps": {
        "from": "00:03:13,440",
        "to": "00:03:17,760"
      },
      "offsets": {
        "from": 193440,
        "to": 197760
      },
      "text": " Görüyeceksiniz ki burada farklı çeşitlerde farklı sonuçları göptüren reklamlar var."
    },
    {
      "timestamps": {
        "from": "00:03:17,760",
        "to": "00:03:23,800"
      },
      "offsets": {
        "from": 197760,
        "to": 203800
      },
      "text": " Bizim amacımız burada satış almak olduğu için seyirası seçiyorum, kontinuyo dediğim zaman beni böyle bir ekranı çıkıyor."
    },
    {
      "timestamps": {
        "from": "00:03:23,800",
        "to": "00:03:26,600"
      },
      "offsets": {
        "from": 203800,
        "to": 206600
      },
      "text": " Zaten reklamlar az buçuk burada bildiğinizi varsayıyorum."
    },
    {
      "timestamps": {
        "from": "00:03:26,600",
        "to": "00:03:29,240"
      },
      "offsets": {
        "from": 206600,
        "to": 209240
      },
      "text": " Sadece çok basit bir şekilde deyini olacağım."
    },
    {
      "timestamps": {
        "from": "00:03:29,240",
        "to": "00:03:34,240"
      },
      "offsets": {
        "from": 209240,
        "to": 214240
      },
      "text": " Şimdi anamantıkta biraz önce anlattığım iyibiyon mantı direkt olarak burada başlıyor."
    },
    {
      "timestamps": {
        "from": "00:03:34,240",
        "to": "00:03:37,520"
      },
      "offsets": {
        "from": 214240,
        "to": 217520
      },
      "text": " Kempeyin bacıt dediği muhabbet kampanya bütçesi diyor."
    },
    {
      "timestamps": {
        "from": "00:03:37,520",
        "to": "00:03:39,920"
      },
      "offsets": {
        "from": 217520,
        "to": 219920
      },
      "text": " Yani ben buraya eğer 25 şuradarsam."
    },
    {
      "timestamps": {
        "from": "00:03:39,920",
        "to": "00:03:43,120"
      },
      "offsets": {
        "from": 219920,
        "to": 223120
      },
      "text": " Ve burada mesela bunları dapli keydedelim."
    },
    {
      "timestamps": {
        "from": "00:03:43,120",
        "to": "00:03:46,040"
      },
      "offsets": {
        "from": 223120,
        "to": 226040
      },
      "text": " Dört tane daha dapli keydedelim, kopyalayalım yani."
    },
    {
      "timestamps": {
        "from": "00:03:46,040",
        "to": "00:03:49,080"
      },
      "offsets": {
        "from": 226040,
        "to": 229080
      },
      "text": " Şimdi gördüğünüz gibi benim burada beş ayrı reklam setim var."
    },
    {
      "timestamps": {
        "from": "00:03:49,080",
        "to": "00:03:52,320"
      },
      "offsets": {
        "from": 229080,
        "to": 232320
      },
