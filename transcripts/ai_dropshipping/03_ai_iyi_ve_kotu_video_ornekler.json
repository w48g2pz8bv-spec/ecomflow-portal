			"timestamps": {
				"from": "00:05:52,960",
				"to": "00:05:54,560"
			},
			"offsets": {
				"from": 352960,
				"to": 354560
			},
			"text": " Hemen onun örneklerine bakalım."
		},
		{
			"timestamps": {
				"from": "00:05:54,560",
				"to": "00:05:56,720"
			},
			"offsets": {
				"from": 354560,
				"to": 356720
			},
			"text": " Mesela burada çok güzel bir hesabımız var."
		},
		{
			"timestamps": {
				"from": "00:05:56,720",
				"to": "00:06:01,680"
			},
			"offsets": {
				"from": 356720,
				"to": 361680
			},
			"text": " Adam, kaç akış sayı, 2.2 milyon paykışımız var bu hesapla."
		},
		{
			"timestamps": {
				"from": "00:06:01,680",
				"to": "00:06:08,160"
			},
			"offsets": {
				"from": 361680,
				"to": 368160
			},
			"text": " Adamla atmış aklınıza gelebilecek her türlü İranç değişik oku denemiş."
		},
		{
			"timestamps": {
				"from": "00:06:08,160",
				"to": "00:06:12,400"
			},
			"offsets": {
				"from": 368160,
				"to": 372400
			},
			"text": " Eğe yolduğu bazılarının çok belli ama hiç fark etmez."
		},
		{
			"timestamps": {
				"from": "00:06:12,400",
				"to": "00:06:13,360"
			},
			"offsets": {
				"from": 372400,
				"to": 373360
			},
			"text": " Neden?"
		},
		{
			"timestamps": {
				"from": "00:06:13,360",
				"to": "00:06:17,120"
			},
			"offsets": {
				"from": 373360,
				"to": 377120
			},
			"text": " Çünkü kitesi eğer buna uygunsa yapabilirsiniz."
		},
		{
			"timestamps": {
				"from": "00:06:17,120",
				"to": "00:06:19,360"
			},
			"offsets": {
				"from": 377120,
				"to": 379360
			},
			"text": " Mesela burada fiyat soranlar var."
		},
		{
			"timestamps": {
				"from": "00:06:19,360",
				"to": "00:06:21,360"
			},
			"offsets": {
				"from": 379360,
				"to": 381360
			},
			"text": " Ayrıca burnunun neredesine alabilirim."
		},
		{
			"timestamps": {
				"from": "00:06:21,360",
				"to": "00:06:22,240"
			},
			"offsets": {
				"from": 381360,
				"to": 382240
			},
			"text": " Türk herhalde."
		},
		{
			"timestamps": {
				"from": "00:06:22,240",
				"to": "00:06:32,480"
			},
			"offsets": {
				"from": 382240,
				"to": 392480
			},
			"text": " Gördüğünüz gibi aşıları yolduğu bile ama ikitesine uyumlu tarzı videolar olmuş."
		},
		{
			"timestamps": {
				"from": "00:06:32,480",
				"to": "00:06:35,360"
			},
			"offsets": {
				"from": 392480,
				"to": 395360
			},
			"text": " Burada sağlık ürünleri satıyor."
		},
		{
			"timestamps": {
				"from": "00:06:35,360",
				"to": "00:06:36,160"
			},
			"offsets": {
				"from": 395360,
				"to": 396160
			},
			"text": " Bin bir türlü."
		},
		{
			"timestamps": {
				"from": "00:06:36,160",
				"to": "00:06:41,040"
			},
			"offsets": {
				"from": 396160,
				"to": 401040
			},
			"text": " Çok güzel yaratıcı kukları var."
		},
		{
			"timestamps": {
				"from": "00:06:41,040",
				"to": "00:06:42,240"
			},
			"offsets": {
				"from": 401040,
				"to": 402240
			},
			"text": " Genel var."
		},
		{
			"timestamps": {
				"from": "00:06:42,240",
				"to": "00:06:48,720"
			},
			"offsets": {
				"from": 402240,
				"to": 408720
			},
			"text": " Böyle ilgi çeken hani scroll stopper tarzı dediğimiz kuklar kullanmış."
		},
		{
			"timestamps": {
				"from": "00:06:52,240",
				"to": "00:07:07,360"
			},
			"offsets": {
				"from": 412240,
				"to": 427360
			},
			"text": " Yani kilo verdiren şeyle o hukma her lakı diye soracak olursanız hiçbir alakası yok ama amaçlı sanırım durdurmak ve gördüğünüz gibi 400 bin izlenmiş."
		},
		{
			"timestamps": {
				"from": "00:07:07,360",
				"to": "00:07:12,320"
			},
			"offsets": {
				"from": 427360,
				"to": 432320
			},
			"text": " Ve gerçekten bir istek var yani bu özüne de."
		},
		{
			"timestamps": {
				"from": "00:07:12,320",
				"to": "00:07:21,840"
			},
			"offsets": {
				"from": 432320,
				"to": 441840
			},
			"text": " Burada da yine farklı farklı değişik değişik İranç kuklar denemiş amaç burada insanları durdurmak dediğimiz gibi burada da 700 bin izlenmesi var."
		},
		{
			"timestamps": {
				"from": "00:07:21,840",
				"to": "00:07:24,240"
			},
			"offsets": {
				"from": 441840,
				"to": 444240
			},
			"text": " 2.2 milyon takipisi var."
		},
		{
			"timestamps": {
				"from": "00:07:24,240",
				"to": "00:07:27,120"
			},
			"offsets": {
				"from": 444240,
				"to": 447120
			},
			"text": " Çok çaki icri olay yapıyordur bu arkadaşımızla."
		}
	]
}
