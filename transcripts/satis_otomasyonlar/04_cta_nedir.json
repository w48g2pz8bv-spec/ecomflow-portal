    {
      "timestamps": {
        "from": "00:07:03,320",
        "to": "00:07:05,040"
      },
      "offsets": {
        "from": 423320,
        "to": 425040
      },
      "text": " Ondan sonra yeni dropladık."
    },
    {
      "timestamps": {
        "from": "00:07:05,040",
        "to": "00:07:06,840"
      },
      "offsets": {
        "from": 425040,
        "to": 426840
      },
      "text": " Link bi' o da diyor ve bitiriyor."
    },
    {
      "timestamps": {
        "from": "00:07:06,840",
        "to": "00:07:09,040"
      },
      "offsets": {
        "from": 426840,
        "to": 429040
      },
      "text": " Bu da benim yaptığım lobanın videosu."
    },
    {
      "timestamps": {
        "from": "00:07:09,040",
        "to": "00:07:11,040"
      },
      "offsets": {
        "from": 429040,
        "to": 431040
      },
      "text": " Ar burada da bir kız konuşması var."
    },
    {
      "timestamps": {
        "from": "00:07:11,040",
        "to": "00:07:13,040"
      },
      "offsets": {
        "from": 431040,
        "to": 433040
      },
      "text": " Umarım ses geliyordur bu arada."
