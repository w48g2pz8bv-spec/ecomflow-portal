    {
      "timestamps": {
        "from": "00:07:29,920",
        "to": "00:07:32,560"
      },
      "offsets": {
        "from": 449920,
        "to": 452560
      },
      "text": " Aynı bu şekilde konuyu anlatıyorum."
    },
    {
      "timestamps": {
        "from": "00:07:32,560",
        "to": "00:07:36,480"
      },
      "offsets": {
        "from": 452560,
        "to": 456480
      },
      "text": " İşte ürünün birazcık daha nasıl kullanıldığını ne yapabileceğini anlatıyorum."
