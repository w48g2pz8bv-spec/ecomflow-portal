      "timestamps": {
        "from": "00:04:38,520",
        "to": "00:04:42,000"
      },
      "offsets": {
        "from": 278520,
        "to": 282000
      },
      "text": " Devamında da burada bak ikinci olarak kendisi yazılı olarak hukatmış."
    },
    {
      "timestamps": {
        "from": "00:04:42,000",
        "to": "00:04:43,320"
      },
      "offsets": {
        "from": 282000,
        "to": 283320
      },
      "text": " Ve emojilerini kullanmış."
    },
    {
      "timestamps": {
        "from": "00:04:43,320",
        "to": "00:04:44,000"
      },
      "offsets": {
        "from": 283320,
        "to": 284000
      },
      "text": " Bakalım."
    },
    {
      "timestamps": {
        "from": "00:04:46,840",
        "to": "00:04:47,840"
      },
      "offsets": {
        "from": 286840,
        "to": 287840
      },
      "text": " Bakamıyoruz."
    },
    {
      "timestamps": {
        "from": "00:04:51,440",
        "to": "00:04:52,600"
      },
      "offsets": {
        "from": 291440,
        "to": 292600
      },
      "text": " Ona bakamıyoruz."
    },
    {
      "timestamps": {
        "from": "00:04:52,600",
        "to": "00:04:55,480"
      },
      "offsets": {
        "from": 292600,
        "to": 295480
      },
      "text": " Bunu birazdan o zaman şey kısmın halledelim."
    },
    {
      "timestamps": {
        "from": "00:04:55,480",
        "to": "00:04:57,320"
      },
      "offsets": {
        "from": 295480,
        "to": 297320
      },
      "text": " Anamantı kadar adam ürünü getiriyor."
    },
    {
      "timestamps": {
        "from": "00:04:57,320",
        "to": "00:04:58,800"
      },
      "offsets": {
        "from": 297320,
        "to": 298800
      },
      "text": " Ürünün şofkeyesini yapıyor."
    },
    {
      "timestamps": {
        "from": "00:04:58,800",
        "to": "00:05:01,800"
      },
      "offsets": {
        "from": 298800,
        "to": 301800
      },
      "text": " Yani nasıl kullanıldığını içine böyle şeylere koyuyor."
    },
    {
      "timestamps": {
        "from": "00:05:01,800",
        "to": "00:05:02,720"
      },
      "offsets": {
        "from": 301800,
        "to": 302720
      },
      "text": " Dendiniyor anladı."
    },
    {
      "timestamps": {
        "from": "00:05:02,720",
        "to": "00:05:04,040"
      },
      "offsets": {
        "from": 302720,
        "to": 304040
      },
      "text": " Benz'in falan koyuyor."
    },
    {
      "timestamps": {
        "from": "00:05:04,040",
        "to": "00:05:05,960"
      },
      "offsets": {
        "from": 304040,
        "to": 305960
      },
      "text": " En sonunda da ürünü git buradan alıyor diyor."
    },
    {
      "timestamps": {
        "from": "00:05:05,960",
        "to": "00:05:08,400"
      },
      "offsets": {
        "from": 305960,
        "to": 308400
      },
      "text": " Ama dediğim gibi neden çalışmadığını bilmiyorum."
    },
    {
      "timestamps": {
        "from": "00:05:08,400",
        "to": "00:05:11,000"
      },
      "offsets": {
        "from": 308400,
        "to": 311000
      },
      "text": " Şimdi bir sonraki kısmı bakarım."
    },
    {
      "timestamps": {
        "from": "00:05:11,000",
        "to": "00:05:14,320"
      },
      "offsets": {
        "from": 311000,
        "to": 314320
      },
      "text": " Burada da viral konsept artık koltayakçın."
    },
    {
      "timestamps": {
        "from": "00:05:14,320",
        "to": "00:05:19,680"
      },
      "offsets": {
        "from": 314320,
        "to": 319680
      },
      "text": " Şimdi gördüğünüz gibi ikisi de hiçbir şekilde ürünün satışa dair olduğunu gösteren bir şekilde başlamıyor."
    },
    {
      "timestamps": {
        "from": "00:05:19,680",
        "to": "00:05:22,160"
      },
      "offsets": {
        "from": 319680,
        "to": 322160
      },
      "text": " Direkt olarak My For World Insight'ın eklas."
    },
    {
      "timestamps": {
        "from": "00:05:22,160",
        "to": "00:05:26,480"
      },
      "offsets": {
        "from": 322160,
        "to": 326480
      },
      "text": " Benim dört dünyam şeyin kol yenin içerisinde olarak başlıyor."
    },
    {
      "timestamps": {
        "from": "00:05:32,720",
        "to": "00:05:47,280"
      },
      "offsets": {
        "from": 332720,
        "to": 347280
      },
      "text": " En sonunda da gördüğünüz gibi direk doğarak koltayakçını yazılı olarak koymuş."
    },
    {
      "timestamps": {
        "from": "00:05:47,280",
        "to": "00:05:49,360"
      },
      "offsets": {
        "from": 347280,
        "to": 349360
      },
      "text": " Burada ilk başta normal doğrak başlıyor."
    },
    {
      "timestamps": {
        "from": "00:05:49,360",
        "to": "00:05:51,680"
      },
      "offsets": {
        "from": 349360,
        "to": 351680
      },
      "text": " Viral konsepti viral hook olarak başlıyor."
    },
    {
      "timestamps": {
        "from": "00:05:51,680",
        "to": "00:05:53,280"
      },
      "offsets": {
        "from": 351680,
        "to": 353280
      },
      "text": " Devamını da koltayakçını atıyor."
    },
    {
      "timestamps": {
        "from": "00:05:53,280",
        "to": "00:05:54,280"
      },
      "offsets": {
        "from": 353280,
        "to": 354280
      },
      "text": " İkinisine bakalım."
    },
    {
      "timestamps": {
        "from": "00:06:02,720",
        "to": "00:06:15,960"
      },
      "offsets": {
        "from": 362720,
        "to": 375960
      },
      "text": " Gördüğünüz gibi aynı şekilde bu İngilizce videoları görmüşsünüzdir."
    },
    {
      "timestamps": {
        "from": "00:06:15,960",
        "to": "00:06:17,440"
      },
      "offsets": {
        "from": 375960,
        "to": 377440
      },
      "text": " It's game it final game."
    },
    {
      "timestamps": {
        "from": "00:06:17,440",
        "to": "00:06:18,680"
      },
      "offsets": {
        "from": 377440,
        "to": 378680
      },
      "text": " İşte geldi sonunda geldi."
    },
    {
      "timestamps": {
        "from": "00:06:18,680",
        "to": "00:06:20,080"
      },
      "offsets": {
        "from": 378680,
        "to": 380080
      },
      "text": " Kutla çalış yapıyorsun."
    },
    {
      "timestamps": {
        "from": "00:06:20,080",
        "to": "00:06:22,480"
      },
      "offsets": {
        "from": 380080,
        "to": 382480
      },
      "text": " En sonunda da ürünün son halini gösteriyorsun."
    },
    {
      "timestamps": {
        "from": "00:06:22,480",
        "to": "00:06:26,640"
      },
      "offsets": {
        "from": 382480,
        "to": 386640
      },
      "text": " Bakın adam ürünün bütün halini gösteriyor ve en sonunda linkin bayağı olarak bitiriyor."
    },
    {
      "timestamps": {
        "from": "00:06:26,640",
        "to": "00:06:29,320"
      },
      "offsets": {
        "from": 386640,
        "to": 389320
      },
      "text": " Bu da ikinci viral koltayakçın konsepimiz."
    },
    {
      "timestamps": {
        "from": "00:06:29,320",
        "to": "00:06:32,400"
      },
      "offsets": {
        "from": 389320,
        "to": 392400
      },
      "text": " Üçüncü olarak da biraz önce bahsettiğim."
    },
    {
      "timestamps": {
        "from": "00:06:32,400",
        "to": "00:06:34,480"
      },
      "offsets": {
        "from": 392400,
        "to": 394480
      },
      "text": " Videoyu içerisinde koltayakçını yerleştirmek."
