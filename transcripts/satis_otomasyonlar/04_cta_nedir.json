    {
      "timestamps": {
        "from": "00:07:36,480",
        "to": "00:07:38,320"
      },
      "offsets": {
        "from": 456480,
        "to": 458320
      },
      "text": " Eşimle kullanıyoruz şu dur budur."
    },
    {
      "timestamps": {
        "from": "00:07:38,320",
        "to": "00:07:41,880"
      },
      "offsets": {
        "from": 458320,
        "to": 461880
      },
      "text": " En sonunda da almak isteyenler için fiyatını profilime koydum."
