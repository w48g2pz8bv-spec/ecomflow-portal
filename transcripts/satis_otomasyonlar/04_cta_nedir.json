    {
      "timestamps": {
        "from": "00:06:36,560",
        "to": "00:06:37,920"
      },
      "offsets": {
        "from": 396560,
        "to": 397920
      },
      "text": " Yani konuyu anlatıyor."
    },
    {
      "timestamps": {
        "from": "00:06:37,920",
        "to": "00:06:39,600"
      },
      "offsets": {
        "from": 397920,
        "to": 399600
      },
      "text": " Bakın burada gene hook kullanabilirsiniz."
    },
    {
      "timestamps": {
        "from": "00:06:39,600",
        "to": "00:06:41,840"
      },
      "offsets": {
        "from": 399600,
        "to": 401840
      },
      "text": " Yani birbirler arasında kombinleyebilirsiniz."
    },
    {
      "timestamps": {
        "from": "00:06:41,840",
        "to": "00:06:43,200"
      },
      "offsets": {
        "from": 401840,
        "to": 403200
      },
      "text": " Ama devamına bakın."
    },
    {
      "timestamps": {
        "from": "00:06:57,440",
        "to": "00:07:00,240"
      },
      "offsets": {
        "from": 417440,
        "to": 420240
      },
      "text": " Görüyor musunuz direk videonun içerisinde?"
    },
    {
      "timestamps": {
        "from": "00:07:00,240",
        "to": "00:07:03,320"
      },
      "offsets": {
        "from": 420240,
        "to": 423320
      },
      "text": " Videonun içerisine adam diyor ki işte ürünün anlatıyor birazcık."
