    {
      "timestamps": {
        "from": "00:07:13,040",
        "to": "00:07:15,000"
      },
      "offsets": {
        "from": 433040,
        "to": 435000
      },
      "text": " Ondan kadar bagaj parası vermiyorum."
    },
    {
      "timestamps": {
        "from": "00:07:15,000",
        "to": "00:07:15,720"
      },
      "offsets": {
        "from": 435000,
        "to": 435720
      },
      "text": " Nasıl mı?"
    },
    {
      "timestamps": {
        "from": "00:07:15,720",
        "to": "00:07:20,800"
      },
      "offsets": {
        "from": 435720,
        "to": 440800
      },
      "text": " Bu çanta sayesinde eşimle üç haftalık kıyafetlerimizi bagaja gerek olmadan taşıyabiliyoruz."
    },
    {
      "timestamps": {
        "from": "00:07:20,800",
        "to": "00:07:24,600"
      },
      "offsets": {
        "from": 440800,
        "to": 444600
      },
      "text": " Üstelik el bagajı kategorisine girip deyi için kilokontrolüne takılmıyor."
    },
    {
      "timestamps": {
        "from": "00:07:24,600",
        "to": "00:07:28,400"
      },
      "offsets": {
        "from": 444600,
        "to": 448400
      },
      "text": " Ve uçağa binince direk o süstü dolar buna koyabiliyorum."
    },
    {
      "timestamps": {
        "from": "00:07:28,400",
        "to": "00:07:29,920"
      },
      "offsets": {
        "from": 448400,
        "to": 449920
      },
      "text": " Fiyatını profilime koydum."
