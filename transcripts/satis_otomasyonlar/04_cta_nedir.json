    {
      "timestamps": {
        "from": "00:07:41,880",
        "to": "00:07:43,840"
      },
      "offsets": {
        "from": 461880,
        "to": 463840
      },
      "text": " Burada bakın şöyle yapmak lazım."
    },
    {
      "timestamps": {
        "from": "00:07:43,840",
        "to": "00:07:47,000"
      },
      "offsets": {
        "from": 463840,
        "to": 467000
      },
      "text": " Specific olarak bir tanesi mükemmel çalışıyor diye bir şey yok."
    },
    {
      "timestamps": {
        "from": "00:07:47,000",
        "to": "00:07:51,680"
      },
      "offsets": {
        "from": 467000,
        "to": 471680
      },
      "text": " O yüzden olabildiğince bu tarz koltayakçınları birbirleriyle kombinleyerek denemeniz lazım."
    },
    {
      "timestamps": {
        "from": "00:07:51,680",
        "to": "00:07:55,320"
      },
      "offsets": {
        "from": 471680,
        "to": 475320
      },
      "text": " Bir de bu koltayakçın videolarıyla eğer viral olmaya başarırsanız."
    },
    {
      "timestamps": {
        "from": "00:07:55,320",
        "to": "00:08:00,640"
      },
      "offsets": {
        "from": 475320,
        "to": 480640
      },
      "text": " O zaman işte günlük böyle bir 50 bin, 100 bin, 200 bin, 300 bin, 500 bin liraları görebiliyor."
    },
    {
      "timestamps": {
        "from": "00:08:00,640",
        "to": "00:08:01,520"
      },
      "offsets": {
        "from": 480640,
        "to": 481520
      },
      "text": " Olacaksınız."
    },
    {
      "timestamps": {
        "from": "00:08:01,520",
        "to": "00:08:03,680"
      },
      "offsets": {
        "from": 481520,
        "to": 483680
      },
      "text": " Türkiye'de hiç yarım milyon organiktan satanı görmedim."
    },
    {
      "timestamps": {
        "from": "00:08:03,680",
        "to": "00:08:07,720"
      },
      "offsets": {
        "from": 483680,
        "to": 487720
      },
      "text": " Gerçi de yurt dışında 10 bin yuro, 20 bin yuro satmak hiç imkansız değil."
    },
    {
      "timestamps": {
        "from": "00:08:07,720",
        "to": "00:08:09,560"
      },
      "offsets": {
        "from": 487720,
        "to": 489560
      },
      "text": " Özellikle hiç lektan para sağlayacağım adam."
    }
  ]
