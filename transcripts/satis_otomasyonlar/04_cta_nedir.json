    {
      "timestamps": {
        "from": "00:06:34,480",
        "to": "00:06:36,560"
      },
      "offsets": {
        "from": 394480,
        "to": 396560
      },
      "text": " Direkt doğarak voice over üzerinden ilerliyor."
