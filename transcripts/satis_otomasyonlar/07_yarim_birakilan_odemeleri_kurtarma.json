      "offsets": {
        "from": 0,
        "to": 4720
      },
      "text": " Evet selamlar. Bu videoda nasıl? Yarın bırakalım demeleri kuturabiliriz."
    },
    {
      "timestamps": {
        "from": "00:00:04,720",
        "to": "00:00:08,920"
      },
      "offsets": {
        "from": 4720,
        "to": 8920
      },
      "text": " Bu yarın bırakalım şöyle demedi. Nasıl spaarişi tamamlayabiliriz."
    },
    {
      "timestamps": {
        "from": "00:00:08,920",
        "to": "00:00:13,520"
      },
      "offsets": {
        "from": 8920,
        "to": 13520
      },
      "text": " Bunları göstereceğim. Evet şimdi Shopify deyiz. Burada uygulamalar üzerinde"
    },
    {
      "timestamps": {
        "from": "00:00:14,960",
        "to": "00:00:18,320"
      },
      "offsets": {
        "from": 14960,
        "to": 18320
      },
      "text": " hep ayarları. Buradan da Shopify hepsi tura gideceğiz."
    },
    {
      "timestamps": {
        "from": "00:00:19,400",
        "to": "00:00:20,720"
      },
      "offsets": {
        "from": 19400,
        "to": 20720
