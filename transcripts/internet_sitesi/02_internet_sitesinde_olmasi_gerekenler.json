			"offsets": {
				"from": 197200,
				"to": 200520
			},
			"text": " Adam burada almaya karar verdiği anda buradan aşağıya gitmeyecek bile."
		},
		{
			"timestamps": {
				"from": "00:03:20,520",
				"to": "00:03:22,000"
			},
			"offsets": {
				"from": 200520,
				"to": 202000
			},
			"text": " Gidecek satın almaya batacak."
		},
		{
			"timestamps": {
				"from": "00:03:22,000",
				"to": "00:03:23,800"
			},
			"offsets": {
				"from": 202000,
				"to": 203800
			},
			"text": " Bam, bam, bam. Gidecek."
		},
		{
			"timestamps": {
				"from": "00:03:23,800",
				"to": "00:03:26,240"
			},
			"offsets": {
				"from": 203800,
				"to": 206240
			},
			"text": " Ha burada çok uzun şeyler yazmamanız lazım."
		},
		{
			"timestamps": {
				"from": "00:03:26,240",
				"to": "00:03:28,960"
			},
			"offsets": {
				"from": 206240,
				"to": 208960
			},
			"text": " Bakın, internet seniz bu kısım çok önemli."
		},
		{
			"timestamps": {
				"from": "00:03:28,960",
				"to": "00:03:31,280"
			},
			"offsets": {
				"from": 208960,
				"to": 211280
			},
			"text": " Çünkü bu kısımın çok fazla öğrenci hata yapıyor."
		},
		{
			"timestamps": {
				"from": "00:03:31,280",
				"to": "00:03:32,920"
			},
			"offsets": {
				"from": 211280,
				"to": 212920
			},
			"text": " Ben sürekli sürekli onları uyarıyorum."
		},
		{
			"timestamps": {
				"from": "00:03:32,920",
				"to": "00:03:35,840"
			},
			"offsets": {
				"from": 212920,
				"to": 215840
			},
			"text": " Internet senizi çok fazla yazı olmaması lazım arkadaşlar."
		},
		{
			"timestamps": {
				"from": "00:03:35,840",
				"to": "00:03:37,680"
			},
			"offsets": {
				"from": 215840,
				"to": 217680
			},
			"text": " Internet sesi bu şeyi biliyorsunuz."
		},
		{
			"timestamps": {
				"from": "00:03:37,680",
				"to": "00:03:39,880"
			},
			"offsets": {
				"from": 217680,
				"to": 219880
			},
			"text": " İnsanlar baktığı zaman fey şeklinde okuyorlar."
		},
		{
			"timestamps": {
				"from": "00:03:39,880",
				"to": "00:03:43,040"
			},
			"offsets": {
				"from": 219880,
				"to": 223040
			},
			"text": " Hani pıt pıt yapıyor, başına sonuna, başına sonuna bakıyor."
		},
		{
			"timestamps": {
				"from": "00:03:43,040",
				"to": "00:03:46,080"
			},
			"offsets": {
				"from": 223040,
				"to": 226080
			},
			"text": " İnsanları olabilince beynini az düşündürmeniz lazım."
		},
		{
			"timestamps": {
				"from": "00:03:46,080",
				"to": "00:03:49,720"
			},
			"offsets": {
				"from": 226080,
				"to": 229720
			},
			"text": " Çünkü satın alma kısmı duyguyla yapılır."
		},
		{
			"timestamps": {
				"from": "00:03:49,720",
				"to": "00:03:52,800"
			},
			"offsets": {
				"from": 229720,
				"to": 232800
			},
			"text": " Eğer siz satın almaya ne zaman beyni sokmaya başlarsanız"
		},
		{
			"timestamps": {
				"from": "00:03:52,800",
				"to": "00:03:55,920"
			},
			"offsets": {
				"from": 232800,
				"to": 235920
			},
			"text": " o zaman işte adamın aklında bir süre farklı sorular gelmeye başlar."
		},
		{
			"timestamps": {
				"from": "00:03:55,920",
				"to": "00:03:59,120"
			},
			"offsets": {
				"from": 235920,
				"to": 239120
			},
			"text": " Böylece yavaş yavaş sizden satın almaktan uzaklaşır."
		},
		{
			"timestamps": {
				"from": "00:03:59,120",
				"to": "00:04:02,040"
			},
			"offsets": {
				"from": 239120,
				"to": 242040
			},
			"text": " Olabilecek insanların beynini az kullandırmamız lazım ki"
		},
		{
			"timestamps": {
				"from": "00:04:02,040",
				"to": "00:04:03,360"
			},
			"offsets": {
				"from": 242040,
				"to": 243360
			},
			"text": " bizden gelip satın alsın."
		},
		{
			"timestamps": {
				"from": "00:04:03,360",
				"to": "00:04:04,120"
			},
			"offsets": {
				"from": 243360,
				"to": 244120
			},
			"text": " Okuyor midir?"
		},
		{
			"timestamps": {
				"from": "00:04:04,120",
				"to": "00:04:08,080"
			},
			"offsets": {
				"from": 244120,
				"to": 248080
			},
			"text": " Burada o yüzden basit olun sadece ana fikri verin"
		},
		{
			"timestamps": {
				"from": "00:04:08,080",
				"to": "00:04:10,040"
			},
			"offsets": {
				"from": 248080,
				"to": 250040
			},
			"text": " ve olayları çok basit bir şekilde anlatın."
		},
		{
			"timestamps": {
				"from": "00:04:10,040",
				"to": "00:04:13,960"
			},
			"offsets": {
				"from": 250040,
				"to": 253960
			},
			"text": " Dediğim gibi 4 bin milyon per değil, 8 saatten fazla pir ömrü."
		},
		{
			"timestamps": {
				"from": "00:04:13,960",
				"to": "00:04:16,440"
			},
			"offsets": {
				"from": 253960,
				"to": 256440
			},
			"text": " Tamam 8 saat, okin 10 numara, 8 saat oynarım."
		},
		{
			"timestamps": {
				"from": "00:04:16,440",
				"to": "00:04:17,600"
			},
			"offsets": {
				"from": 256440,
				"to": 257600
			},
			"text": " Adam böyle düşünmesi lazım."
		},
		{
			"timestamps": {
				"from": "00:04:17,600",
				"to": "00:04:20,400"
			},
			"offsets": {
				"from": 257600,
				"to": 260400
			},
			"text": " 4 bin milyon per yani bu kaç saat gider, 10 saat gider."
		},
		{
			"timestamps": {
				"from": "00:04:20,400",
				"to": "00:04:22,200"
			},
			"offsets": {
				"from": 260400,
				"to": 262200
			},
			"text": " Adamın böyle düşündürmememiz lazım."
		},
		{
			"timestamps": {
				"from": "00:04:22,200",
				"to": "00:04:27,320"
			},
			"offsets": {
				"from": 262200,
				"to": 267320
			},
			"text": " Sosyal kanıt kısmın geldik işin insanları yavaştan ikna etme kısmına."
		},
		{
			"timestamps": {
				"from": "00:04:27,320",
				"to": "00:04:31,800"
			},
			"offsets": {
				"from": 267320,
				"to": 271800
			},
			"text": " Sosyal kanıt kısmı insanlarla birazcık daha kendimizi güvendireceğimiz kısmı olacak."
		},
		{
			"timestamps": {
				"from": "00:04:31,800",
				"to": "00:04:34,200"
			},
			"offsets": {
				"from": 271800,
				"to": 274200
			},
			"text": " Burada satın alma kararlarını hızlandırıyor olacağız."
		},
		{
			"timestamps": {
				"from": "00:04:34,200",
				"to": "00:04:37,520"
			},
			"offsets": {
				"from": 274200,
				"to": 277520
			},
			"text": " 6 ve 20 m2 arasında ücretsiz teslim olun."
		},
		{
			"timestamps": {
				"from": "00:04:37,520",
				"to": "00:04:40,680"
			},
			"offsets": {
				"from": 277520,
				"to": 280680
			},
			"text": " Bunun daha gelişmiş hali popkanında var, onun direkt kodunu süre vereceğim."
		},
		{
			"timestamps": {
				"from": "00:04:40,680",
				"to": "00:04:42,880"
			},
			"offsets": {
				"from": 280680,
				"to": 282880
			},
			"text": " İnternesi denizi otomatik olarak koyabileceksiniz."
		},
		{
			"timestamps": {
				"from": "00:04:42,880",
				"to": "00:04:45,320"
			},
			"offsets": {
				"from": 282880,
				"to": 285320
			},
			"text": " Ürşey kısmında, web ses kısmında konuşuruz."
		},
		{
			"timestamps": {
				"from": "00:04:45,320",
				"to": "00:04:49,080"
			},
			"offsets": {
				"from": 285320,
				"to": 289080
			},
			"text": " Burada ki amaç insanlar baktığı zaman demeleri lazım ki tamam."
		},
		{
			"timestamps": {
				"from": "00:04:49,080",
				"to": "00:04:52,240"
			},
			"offsets": {
				"from": 289080,
				"to": 292240
			},
			"text": " Ben hani bunun ne zaman teslim alabilirim diye düşünmemeler lazım."
		},
		{
			"timestamps": {
				"from": "00:04:52,240",
				"to": "00:04:55,360"
			},
			"offsets": {
				"from": 292240,
				"to": 295360
			},
			"text": " Baktıkları zaman 6 ve 21 m2 arasında ücretsiz teslim olun."
		},
		{
			"timestamps": {
				"from": "00:04:55,360",
				"to": "00:04:58,760"
			},
			"offsets": {
				"from": 295360,
				"to": 298760
			},
			"text": " Adam buraya baktığı zaman 6'ı görüyor, 21'ü görüyor direkt tamam o zaman."
		},
		{
			"timestamps": {
				"from": "00:04:58,760",
				"to": "00:05:00,320"
			},
			"offsets": {
				"from": 298760,
				"to": 300320
			},
			"text": " Ben 10-15 gibi alırım diyor tamam."
		},
		{
			"timestamps": {
				"from": "00:05:00,320",
				"to": "00:05:01,760"
			},
			"offsets": {
				"from": 300320,
				"to": 301760
			},
			"text": " Ana fikri verdiyseniz okey."
		},
		{
			"timestamps": {
				"from": "00:05:01,760",
				"to": "00:05:04,680"
			},
			"offsets": {
				"from": 301760,
				"to": 304680
			},
			"text": " İkinci olarak da ürünün altına geldiği zaman"
		},
		{
			"timestamps": {
				"from": "00:05:04,680",
				"to": "00:05:07,920"
			},
			"offsets": {
				"from": 304680,
				"to": 307920
			},
			"text": " direkt olarak birkaç tane yorum koymanız çok verimli."
		},
		{
			"timestamps": {
				"from": "00:05:07,920",
				"to": "00:05:10,800"
			},
			"offsets": {
				"from": 307920,
				"to": 310800
			},
			"text": " Burada amaç müşteriler yorumları görmek için"
		},
		{
			"timestamps": {
				"from": "00:05:10,800",
				"to": "00:05:13,840"
			},
			"offsets": {
				"from": 310800,
				"to": 313840
			},
			"text": " ta sayfanın en altına gitmelerini önlemeleri için."
		},
		{
			"timestamps": {
				"from": "00:05:13,840",
				"to": "00:05:15,840"
			},
			"offsets": {
				"from": 313840,
				"to": 315840
			},
			"text": " Direkt olarak kaydırmaya başladıklarında"
		},
		{
			"timestamps": {
				"from": "00:05:15,840",
				"to": "00:05:18,000"
			},
			"offsets": {
				"from": 315840,
				"to": 318000
			},
			"text": " 2-3 tane oraya basit yorumları atın ki"
		},
		{
			"timestamps": {
				"from": "00:05:18,000",
				"to": "00:05:19,640"
			},
			"offsets": {
				"from": 318000,
				"to": 319640
			},
			"text": " insanlar görsindesin ki tamam."
		},
		{
			"timestamps": {
				"from": "00:05:19,640",
				"to": "00:05:22,760"
			},
			"offsets": {
				"from": 319640,
				"to": 322760
			},
			"text": " Anamantıkta bunu ben alabilirim bunu seveyim."
		},
		{
			"timestamps": {
				"from": "00:05:22,760",
				"to": "00:05:26,840"
			},
			"offsets": {
				"from": 322760,
				"to": 326840
			},
			"text": " Bu kısmı önemli insanlar rektama diye diğer insanların deneyimlerine güvenir."
		},
		{
			"timestamps": {
				"from": "00:05:26,840",
				"to": "00:05:30,080"
			},
			"offsets": {
				"from": 326840,
				"to": 330080
			},
			"text": " Dediğim gibi çünkü insanlar bilir ki reklamın amacı onlara satış yapmak."
		},
		{
			"timestamps": {
				"from": "00:05:30,080",
				"to": "00:05:32,960"
			},
			"offsets": {
				"from": 330080,
				"to": 332960
			},
			"text": " Ama burada mutlu insanlar gördükleri zaman"
		},
		{
			"timestamps": {
				"from": "00:05:32,960",
				"to": "00:05:37,840"
			},
			"offsets": {
				"from": 332960,
				"to": 337840
			},
			"text": " mistr gökran kağı gibi ne olur insanlar bunlara güvenir arkadaşlar."
		},
		{
			"timestamps": {
				"from": "00:05:37,840",
				"to": "00:05:40,560"
			},
			"offsets": {
				"from": 337840,
				"to": 340560
			},
			"text": " Web sitesinin devam kısmı aşağı indik."
		},
		{
			"timestamps": {
				"from": "00:05:40,560",
				"to": "00:05:43,400"
			},
			"offsets": {
				"from": 340560,
				"to": 343400
			},
			"text": " Burada genel olarak strateji çok basit."
		},
		{
			"timestamps": {
				"from": "00:05:43,400",
				"to": "00:05:48,400"
			},
			"offsets": {
				"from": 343400,
				"to": 348400
			},
			"text": " 2 tane bir tane gif, bir tane açıklama, altına bir tane gif, bir tane açıklama."
		},
		{
			"timestamps": {
				"from": "00:05:48,400",
				"to": "00:05:51,760"
			},
			"offsets": {
				"from": 348400,
				"to": 351760
			},
			"text": " Toplamda 2 tane gif, 2 tane açıklama koyuyoruz ve kapatıyoruz."
		},
		{
			"timestamps": {
				"from": "00:05:51,760",
				"to": "00:05:55,360"
			},
			"offsets": {
				"from": 351760,
				"to": 355360
			},
			"text": " Burada ki gifin amacı da ürünün kullanımda nasıl gözüküceğini"
		},
		{
			"timestamps": {
				"from": "00:05:55,360",
				"to": "00:05:58,840"
			},
			"offsets": {
				"from": 355360,
				"to": 358840
			},
			"text": " insanlara gösterip varsa valfaktörünü belirtip"
		},
		{
			"timestamps": {
				"from": "00:05:58,840",
				"to": "00:06:01,400"
			},
			"offsets": {
				"from": 358840,
				"to": 361400
			},
			"text": " devamında basit ve açıklama yazmanız lazım."
		},
		{
			"timestamps": {
				"from": "00:06:01,400",
				"to": "00:06:04,840"
			},
			"offsets": {
				"from": 361400,
				"to": 364840
			},
			"text": " Burada ürünün eğer mesela ışın açtığınızda daha da parlıyorsa"
		},
		{
			"timestamps": {
				"from": "00:06:04,840",
				"to": "00:06:07,800"
			},
			"offsets": {
				"from": 364840,
				"to": 367800
			},
			"text": " tam buşun açılma yerine mesela gif olarak alabilirsiniz."
		},
		{
			"timestamps": {
				"from": "00:06:07,800",
				"to": "00:06:10,480"
			},
			"offsets": {
				"from": 367800,
				"to": 370480
			},
			"text": " Bunları yapması çok kolay, videonuza ezgif atıyorsunuz."
		},
		{
			"timestamps": {
				"from": "00:06:10,480",
				"to": "00:06:12,880"
			},
			"offsets": {
				"from": 370480,
				"to": 372880
			},
			"text": " Oradan yapıyorsunuz bunları beraber yapabiliriz."
		},
		{
			"timestamps": {
				"from": "00:06:12,880",
				"to": "00:06:16,880"
			},
			"offsets": {
				"from": 372880,
				"to": 376880
			},
			"text": " Dediğim gibi olay olabildiğince insanlar ürün aldıkları zaman"
		},
		{
			"timestamps": {
				"from": "00:06:16,880",
				"to": "00:06:18,520"
			},
			"offsets": {
				"from": 376880,
				"to": 378520
			},
			"text": " ne gibi bir şey alacaklarını."
		},
		{
			"timestamps": {
				"from": "00:06:18,520",
				"to": "00:06:22,560"
			},
			"offsets": {
				"from": 378520,
				"to": 382560
			},
			"text": " Bu ürünün nasıl kullanıldığını ya da valfaktörünü gösterebiliyor."
		},
		{
			"timestamps": {
				"from": "00:06:22,560",
				"to": "00:06:23,560"
			},
			"offsets": {
				"from": 382560,
				"to": 383560
			},
			"text": " Olmak."
		},
		{
			"timestamps": {
				"from": "00:06:23,560",
				"to": "00:06:26,640"
			},
			"offsets": {
				"from": 383560,
				"to": 386640
			},
			"text": " Aslında ben bunu hazırlamıştım da bu demek araya kaynamış."
		},
		{
			"timestamps": {
				"from": "00:06:26,640",
				"to": "00:06:28,040"
			},
			"offsets": {
				"from": 386640,
				"to": 388040
			},
			"text": " Bunu oksak daha iyi olur."
		},
		{
			"timestamps": {
				"from": "00:06:28,040",
				"to": "00:06:30,240"
			},
			"offsets": {
				"from": 388040,
				"to": 390240
			},
			"text": " Ürünün gerçek kullanımını gösterir."
		},
		{
			"timestamps": {
				"from": "00:06:30,240",
				"to": "00:06:35,160"
			},
			"offsets": {
				"from": 390240,
				"to": 395160
			},
			"text": " Nasıl çalışıyor sorusunda anında cevaplar ürünün vav etkisini ortaya çıkartır."
		},
		{
			"timestamps": {
				"from": "00:06:35,160",
				"to": "00:06:38,560"
			},
			"offsets": {
				"from": 395160,
				"to": 398560
			},
			"text": " Yani hareketli görseler burada insanlar ilk baktığı zaman"
		},
		{
			"timestamps": {
				"from": "00:06:38,560",
				"to": "00:06:40,760"
			},
			"offsets": {
				"from": 398560,
				"to": 400760
			},
			"text": " derini görmeleri lazım."
		},
		{
			"timestamps": {
				"from": "00:06:40,760",
				"to": "00:06:43,680"
			},
			"offsets": {
				"from": 400760,
				"to": 403680
			},
			"text": " Ve devamında da kısa ve net bir açıklama yapmanız lazım."
		},
		{
			"timestamps": {
				"from": "00:06:43,680",
				"to": "00:06:45,400"
			},
			"offsets": {
				"from": 403680,
				"to": 405400
			},
			"text": " Sonra olarak da sıkça sorulan sorular."
		},
		{
			"timestamps": {
				"from": "00:06:45,400",
				"to": "00:06:48,240"
			},
			"offsets": {
				"from": 405400,
				"to": 408240
			},
			"text": " Bakın sıkça sorulan soruların internet sınıza eklemeziniz lazım."
		},
		{
			"timestamps": {
				"from": "00:06:48,240",
				"to": "00:06:49,440"
			},
			"offsets": {
				"from": 408240,
				"to": 409440
			},
			"text": " Bu kısmında gerçekten önemli."
		},
		{
			"timestamps": {
				"from": "00:06:49,440",
				"to": "00:06:49,960"
			},
			"offsets": {
				"from": 409440,
				"to": 409960
			},
			"text": " Neden?"
		},
		{
			"timestamps": {
				"from": "00:06:49,960",
				"to": "00:06:53,960"
			},
			"offsets": {
				"from": 409960,
				"to": 413960
			},
			"text": " Çünkü sıkça sorulan sorular kısmı müşteriyen aklına gelebilecek"
		},
		{
			"timestamps": {
				"from": "00:06:53,960",
				"to": "00:06:56,200"
			},
			"offsets": {
				"from": 413960,
				"to": 416200
			},
			"text": " soruları önceden cevaplaması lazım."
		},
		{
			"timestamps": {
				"from": "00:06:56,200",
				"to": "00:06:59,000"
			},
			"offsets": {
				"from": 416200,
				"to": 419000
			},
			"text": " Adam bu sor bu sinyonunuza baktığı zaman."
		},
		{
			"timestamps": {
				"from": "00:06:59,000",
				"to": "00:07:00,480"
			},
			"offsets": {
				"from": 419000,
				"to": 420480
			},
			"text": " Acaba bu böyle olur mu?"
		},
		{
			"timestamps": {
				"from": "00:07:00,480",
				"to": "00:07:02,480"
			},
			"offsets": {
				"from": 420480,
				"to": 422480
			},
			"text": " Acaba bunu böyle alsan böyle yapabilir miyim?"
		},
		{
			"timestamps": {
				"from": "00:07:02,480",
				"to": "00:07:07,360"
			},
			"offsets": {
				"from": 422480,
				"to": 427360
			},
			"text": " Burada direkt olarak onun sorularına artık cevapladığımız bütün soruları kapattığımız kısmı olmalı."
		},
		{
			"timestamps": {
				"from": "00:07:07,360",
				"to": "00:07:09,200"
			},
			"offsets": {
				"from": 427360,
				"to": 429200
			},
			"text": " Mesela burada baktığınız zaman"
		},
		{
			"timestamps": {
				"from": "00:07:09,200",
				"to": "00:07:12,240"
			},
			"offsets": {
				"from": 429200,
				"to": 432240
			},
			"text": " pokokonsonun içerisinde bir ran fazla depolama seçene olduğu için"
		},
		{
			"timestamps": {
				"from": "00:07:12,240",
				"to": "00:07:15,400"
			},
			"offsets": {
				"from": 432240,
				"to": 435400
			},
			"text": " hangi depolama seçenini seçmeliyim diye up uzun bir alan var?"
		},
		{
			"timestamps": {
				"from": "00:07:15,400",
				"to": "00:07:16,400"
			},
			"offsets": {
				"from": 435400,
				"to": 436400
			},
			"text": " Bakın."
		},
		{
			"timestamps": {
				"from": "00:07:16,400",
				"to": "00:07:17,200"
			},
			"offsets": {
				"from": 436400,
				"to": 437200
			},
			"text": " Tü tü tü."
		},
		{
			"timestamps": {
				"from": "00:07:17,200",
				"to": "00:07:18,600"
			},
			"offsets": {
				"from": 437200,
				"to": 438600
			},
			"text": " Hangi depolama alanı seçmeliyim?"
		},
		{
			"timestamps": {
				"from": "00:07:18,600",
				"to": "00:07:19,960"
			},
			"offsets": {
				"from": 438600,
				"to": 439960
			},
			"text": " Görüyor musun açıklamalara?"
		},
		{
			"timestamps": {
				"from": "00:07:19,960",
				"to": "00:07:22,320"
			},
			"offsets": {
				"from": 439960,
				"to": 442320
			},
			"text": " Burada amaç insanları ikna etmek."
		},
		{
			"timestamps": {
				"from": "00:07:22,320",
				"to": "00:07:26,200"
			},
			"offsets": {
				"from": 442320,
				"to": 446200
			},
			"text": " Çünkü adam artık satın almayı gelmiş, kararını vermek üzere."
		},
		{
			"timestamps": {
				"from": "00:07:26,200",
				"to": "00:07:29,360"
			},
			"offsets": {
				"from": 446200,
				"to": 449360
			},
			"text": " Ama diyor ki hangisine asam acaba mantıklı olur, bunu düşünüyor."
		},
		{
			"timestamps": {
				"from": "00:07:29,360",
				"to": "00:07:32,200"
			},
			"offsets": {
				"from": 449360,
				"to": 452200
			},
			"text": " Diyorsun ki, kri sekiz depolama istiyorsan bunu al."
		},
		{
			"timestamps": {
				"from": "00:07:32,200",
				"to": "00:07:33,960"
			},
			"offsets": {
				"from": 452200,
				"to": 453960
			},
			"text": " Seksen istiyorsan git bunu al."
		},
		{
			"timestamps": {
				"from": "00:07:33,960",
				"to": "00:07:35,840"
			},
			"offsets": {
				"from": 453960,
				"to": 455840
			},
			"text": " 144 istiyorsan git bunu al."
		},
		{
			"timestamps": {
				"from": "00:07:35,840",
				"to": "00:07:37,560"
			},
			"offsets": {
				"from": 455840,
				"to": 457560
			},
			"text": " 72 istiyorsan git bunu al."
		},
		{
			"timestamps": {
				"from": "00:07:37,560",
				"to": "00:07:39,920"
			},
			"offsets": {
				"from": 457560,
				"to": 459920
			},
			"text": " Bu bizim iş de en çok satamlığınız şunu bunu."
		},
		{
			"timestamps": {
				"from": "00:07:39,920",
				"to": "00:07:42,640"
			},
			"offsets": {
				"from": 459920,
				"to": 462640
			},
			"text": " Burada ki amaç adamı olabildiğince artık ikna etmek."
		},
		{
			"timestamps": {
				"from": "00:07:42,640",
				"to": "00:07:44,480"
			},
			"offsets": {
				"from": 462640,
				"to": 464480
			},
			"text": " Çünkü adam zaten almayı kafayı koymuş."
		},
		{
			"timestamps": {
				"from": "00:07:44,480",
				"to": "00:07:47,320"
			},
			"offsets": {
				"from": 464480,
				"to": 467320
			},
			"text": " Hangisine acaba alsan benim için mantıklı olur diye düşünüyor."
		},
		{
			"timestamps": {
				"from": "00:07:47,320",
				"to": "00:07:49,640"
			},
			"offsets": {
				"from": 467320,
				"to": 469640
			},
			"text": " İkinci olarak sorabilecekleri sorup pil ömrüne kadar."
		},
		{
			"timestamps": {
				"from": "00:07:49,640",
				"to": "00:07:52,120"
			},
			"offsets": {
				"from": 469640,
				"to": 472120
			},
			"text": " 30 dakikada şarz et, 8 sade kadar dayansın."
		},
		{
			"timestamps": {
				"from": "00:07:52,120",
				"to": "00:07:52,640"
			},
			"offsets": {
				"from": 472120,
				"to": 472640
			},
			"text": " Bu kadar."
		},
		{
			"timestamps": {
				"from": "00:07:52,640",
				"to": "00:07:56,000"
			},
			"offsets": {
				"from": 472640,
				"to": 476000
			},
			"text": " Çok ekstrem böyle uçuk kaçık detaylar bilgiler vermenizi gerek."
		},
		{
			"timestamps": {
				"from": "00:07:56,000",
				"to": "00:07:57,000"
			},
			"offsets": {
				"from": 476000,
				"to": 477000
			},
			"text": " Yok burada."
		},
		{
			"timestamps": {
				"from": "00:07:57,000",
				"to": "00:07:59,000"
			},
			"offsets": {
				"from": 477000,
				"to": 479000
			},
			"text": " Devamına nasıl daha fazla oynandırabilirim."
		},
		{
			"timestamps": {
				"from": "00:07:59,000",
				"to": "00:08:00,440"
			},
			"offsets": {
				"from": 479000,
				"to": 480440
			},
			"text": " Yani bu birazcık teknik bilgi."
		},
		{
			"timestamps": {
				"from": "00:08:00,440",
				"to": "00:08:04,240"
			},
			"offsets": {
				"from": 480440,
				"to": 484240
			},
			"text": " Çünkü yani o ekstra esni karda oynandığı büklüğe biliyorlar müşteriler."
		},
		{
			"timestamps": {
				"from": "00:08:04,240",
				"to": "00:08:07,440"
			},
			"offsets": {
				"from": 484240,
				"to": 487440
			},
			"text": " O yüzden buradan nasıl bunu indirebülkleyebileceklerini gösterelimiz."
		},
		{
			"timestamps": {
				"from": "00:08:07,440",
				"to": "00:08:10,720"
			},
			"offsets": {
				"from": 487440,
				"to": 490720
			},
			"text": " Kızım, kullanma talimatlarında neler yapmaları gerektiği."
		},
		{
			"timestamps": {
				"from": "00:08:10,720",
				"to": "00:08:14,840"
			},
			"offsets": {
				"from": 490720,
				"to": 494840
			},
			"text": " Ya ürün teknolojik ve birazcık karmaşık olduğu için biraz fazla açıklama var."
		},
		{
			"timestamps": {
				"from": "00:08:14,840",
				"to": "00:08:19,280"
			},
			"offsets": {
				"from": 494840,
				"to": 499280
			},
			"text": " Belki bu kadar ekstra fazla açıklama koymasanız kendi ürününüzde yer aklınıza bulunsun."
		},
		{
			"timestamps": {
				"from": "00:08:19,280",
				"to": "00:08:25,760"
			},
			"offsets": {
				"from": 499280,
				"to": 505760
			},
			"text": " Ama eğer ürün böyle teknoloji ürünü ise insanlar gerçekten nasıl kullanması gerektiğini bilmesi gerekiyorsa."
		},
		{
			"timestamps": {
				"from": "00:08:25,760",
				"to": "00:08:26,840"
			},
			"offsets": {
				"from": 505760,
				"to": 506840
			},
			"text": " Böyle açıklamalar lazım."
		},
		{
			"timestamps": {
				"from": "00:08:26,840",
				"to": "00:08:27,840"
			},
			"offsets": {
				"from": 506840,
				"to": 507840
			},
			"text": " Her şart da."
		},
		{
			"timestamps": {
				"from": "00:08:27,840",
				"to": "00:08:30,880"
			},
			"offsets": {
				"from": 507840,
				"to": 510880
			},
			"text": " İçerisine ne gibi konsollar mevcut, kargom ne kadar sürüyor."
		},
		{
			"timestamps": {
				"from": "00:08:30,880",
				"to": "00:08:34,000"
			},
			"offsets": {
				"from": 510880,
				"to": 514000
			},
			"text": " Türkiye yine de kargınızı ilk sipariş yüzde tamamen ücretsizdir."
		},
		{
			"timestamps": {
				"from": "00:08:34,000",
				"to": "00:08:37,880"
			},
			"offsets": {
				"from": 514000,
				"to": 517880
			},
			"text": " Bulunduğunuz ile bağlı olarak yediği ile 15 gün, 15 iş günü sürer."
		},
		{
			"timestamps": {
				"from": "00:08:37,880",
				"to": "00:08:42,720"
			},
			"offsets": {
				"from": 517880,
				"to": 522720
			},
			"text": " Bu arada bilgisayardan çok temiz gözüküyor da içeriden nasıl gözüküyor bilmiyorum."
		},
		{
			"timestamps": {
				"from": "00:08:42,720",
				"to": "00:08:49,920"
			},
			"offsets": {
				"from": 522720,
				"to": 529920
			},
			"text": " Başka soruların varsa da destek et poko konsol nokta komutan gelip benimle görevişe bilirsiniz diyorum."
		},
		{
			"timestamps": {
				"from": "00:08:49,920",
				"to": "00:08:53,600"
			},
			"offsets": {
				"from": 529920,
				"to": 533600
			},
			"text": " Son olarak yorumlar bakın yorumlar çok önemli."
		},
		{
			"timestamps": {
				"from": "00:08:53,600",
				"to": "00:08:59,120"
			},
			"offsets": {
				"from": 533600,
				"to": 539120
			},
			"text": " Burada yorumlarınızın gerçekten fotoğraflı bir şekilde ve güzel açıklamalı olması lazım."
		},
		{
			"timestamps": {
				"from": "00:08:59,120",
				"to": "00:09:02,480"
			},
			"offsets": {
				"from": 539120,
				"to": 542480
			},
			"text": " Çünkü burası adamların en son karar vermen noktası."
		},
		{
			"timestamps": {
				"from": "00:09:02,480",
				"to": "00:09:08,320"
			},
			"offsets": {
				"from": 542480,
				"to": 548320
			},
			"text": " Eğer sinmişteniz gelirse satın almak istiyorsa ama güvenemiyorsa tam olarak ikna edeceğimiz mekanın burası."
		},
		{
			"timestamps": {
				"from": "00:09:08,320",
				"to": "00:09:11,200"
			},
			"offsets": {
				"from": 548320,
				"to": 551200
			},
			"text": " Burada gerçek kullanıcı neneğimlerini göstermek lazım."
		},
		{
			"timestamps": {
				"from": "00:09:11,200",
				"to": "00:09:17,680"
			},
			"offsets": {
				"from": 551200,
				"to": 557680
			},
			"text": " O yüzden Aleyk Spresten direkt kopyalayıp bozuk Türkçe ile bozuk İngilizce ile şey yapmamanız lazım."
		},
		{
			"timestamps": {
				"from": "00:09:17,680",
				"to": "00:09:21,000"
			},
			"offsets": {
				"from": 557680,
				"to": 561000
			},
			"text": " Gerçekten bu yorumların açıklamalarınız iyi okumanız lazım."
		},
		{
			"timestamps": {
				"from": "00:09:21,000",
				"to": "00:09:26,160"
			},
			"offsets": {
				"from": 561000,
				"to": 566160
			},
			"text": " Burada çekçibiti yazdırabilirsiniz yorumları. İnsan yazımı şeklinde gözüküğüne kesinlikle şey yapmamız lazım."
		},
		{
			"timestamps": {
				"from": "00:09:26,160",
				"to": "00:09:27,240"
			},
			"offsets": {
				"from": 566160,
				"to": 567240
			},
			"text": " Hem fikir olmamız lazım."
		},
		{
			"timestamps": {
				"from": "00:09:27,240",
				"to": "00:09:29,200"
			},
			"offsets": {
				"from": 567240,
				"to": 569200
			},
			"text": " Mesela çok robot var ya olmaması lazım."
		},
		{
			"timestamps": {
				"from": "00:09:29,200",
				"to": "00:09:33,240"
			},
			"offsets": {
				"from": 569200,
				"to": 573240
			},
			"text": " Çünkü okuyanı insanlar da günün sonunda insana itabediyoruz."
		},
		{
			"timestamps": {
				"from": "00:09:33,240",
				"to": "00:09:35,880"
			},
			"offsets": {
				"from": 573240,
				"to": 575880
			},
			"text": " Çok eğer yuvarı olursa insanlar bunu alnıyorlar arkadaşlar."
		},
		{
			"timestamps": {
				"from": "00:09:35,880",
				"to": "00:09:36,960"
			},
			"offsets": {
				"from": 575880,
				"to": 576960
			},
			"text": " Buna dikkat etmek lazım."
		},
		{
			"timestamps": {
				"from": "00:09:36,960",
				"to": "00:09:39,880"
			},
			"offsets": {
				"from": 576960,
				"to": 579880
			},
